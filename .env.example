# Solana RPC
NEXT_PUBLIC_SOLANA_RPC_URL=https://forkit-2a5ac542.gateway.tatum.io/
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# JWT secret for wallet auth — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-change-me

# Base URL for forkit-site (used for CORS and share links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# URL of the forkme front-end site (added to CORS allowed origins)
FORKME_URL=https://forkme.example.com

# Database (Postgres). On Vercel + Neon, both are auto-set when you attach
# the Storage integration. DIRECT_URL is the unpooled connection used by
# `prisma migrate` / `prisma db push`; DATABASE_URL is the pooled one used
# at runtime.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# Vercel Blob — auto-set when you attach a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Forkit smart contract address on Solana
# NEXT_PUBLIC_FORKIT_PROGRAM_ID=<program_id>
