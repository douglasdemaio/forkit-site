generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String     @id @default(uuid())
  wallet      String
  payoutWallet String?
  name        String
  slug        String     @unique
  description String     @default("")
  template    String     @default("classic-bistro")
  logo        String?
  banner      String?
  currency    String     @default("USDC")
  deliveryFee Float      @default(0)
  published   Boolean    @default(false)
  autoAcknowledge Boolean @default(false)
  selfDelivery    Boolean @default(false)
  addressStreet   String?
  addressCity     String?
  addressCountry  String?
  colorPrimary    String?
  colorSecondary  String?
  colorAccent     String?
  fontFamily      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menuItems   MenuItem[]
  orders      Order[]

  @@index([wallet])
}

model MenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String     @default("")
  price        Float
  image        String?
  category     String     @default("Main")
  available    Boolean    @default(true)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model Order {
  id              String         @id @default(uuid())
  restaurantId    String
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id])
  customerWallet  String
  items           String
  tokenMint       String?
  foodTotal              Float          @default(0)
  deliveryFee            Float          @default(0)
  escrowTarget           Float          @default(0)
  escrowFunded           Float          @default(0)
  status                 String         @default("Created")
  driverWallet           String?
  bidOpenAt              DateTime?
  settleTxSignature      String?
  onChainOrderId         String?
  codeA                  String?
  codeB                  String?
  codeAHash              String?
  codeBHash              String?
  deliveryAddress        String?
  shareLink              String?        @unique
  requestedDeliveryTime  DateTime?
  requestedPickupTime    DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  contributions          Contribution[]
  driverBids             DriverBid[]
  driverRatings          DeliveryRating[]

  @@index([restaurantId])
  @@index([customerWallet])
  @@index([driverWallet])
  @@index([status])
}

model Contribution {
  id                String   @id @default(uuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  contributorWallet String
  amount            Float
  txSignature       String?
  createdAt         DateTime @default(now())

  @@index([orderId])
}

model DriverProfile {
  wallet               String   @id
  completedDeliveries  Int      @default(0)
  avgRating            Float    @default(0)
  ratingCount          Int      @default(0)
  vehicleType          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CustomerProfile {
  wallet     String   @id
  preferEco  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DriverBid {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverWallet String
  status       String   @default("Pending") // Pending | Accepted | Rejected | Expired
  createdAt    DateTime @default(now())

  @@unique([orderId, driverWallet])
  @@index([orderId])
  @@index([driverWallet])
}

model DeliveryRating {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverWallet String
  raterWallet  String
  raterRole    String   // "restaurant" | "customer"
  rating       Int      // 1–5
  comment      String?
  createdAt    DateTime @default(now())

  @@unique([orderId, raterRole])
  @@index([orderId])
  @@index([driverWallet])
}

model Nonce {
  id        String   @id @default(uuid())
  wallet    String
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([wallet])
}
